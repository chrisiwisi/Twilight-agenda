rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /sessions/{sessionId} {
      // Anyone may read — needed for joining, watching, and existence checks
      allow read: if true;

      // Anyone may create a new session with a valid initial structure
      allow create: if isValidSession(request.resource.data);

      // Anyone may update a session (join / leave / advance status)
      // Validates the resulting document state after the write
      allow update: if isValidSession(request.resource.data);

      // The app never deletes sessions
      allow delete: if false;
    }

    match /votes/{voteId} {
      allow read: if true;
      allow create: if isValidVote(request.resource.data);
      allow update: if false; // only cloud function (admin SDK) touches this
      allow delete: if false;
    }

    match /votes/{voteId}/ballots/{playerId} {
      allow read: if true;
      allow create, update: if isValidBallot(request.resource.data)
        && isPlayerInSession(voteId, playerId, database);
      allow delete: if false;
    }
  }
  // ── helpers ──────────────────────────────────────────────────────────────

  function isValidSession(data) {
    return data.keys().hasAll(['status', 'players'])
      && data.status is string
      && data.status in ['lobby', 'voting', 'results']
      && data.players is map
      && data.players.size() <= 50
      && (!('voteId' in data) || data.voteId is string)
      && (!('speakerId' in data) || data.speakerId is string);
  }

  function isValidVote(data) {
    return data.keys().hasAll(['sessionId', 'createdAt', 'type'])
      && data.sessionId is string
      && data.type in ['binary', 'player', 'free'];
  }

  function isValidBallot(data) {
    return data.keys().hasAll(['choice', 'influence', 'submittedAt'])
      && data.choice is string
      && data.choice.size() > 0
      && data.influence is number
      && data.influence >= 0;
  }

  function isPlayerInSession(voteId, playerId, database) {
    let sessionId = get(/databases/$(database)/documents/votes/$(voteId)).data.sessionId;
    let session = get(/databases/$(database)/documents/sessions/$(sessionId)).data;
    return playerId in session.players;
  }
}
